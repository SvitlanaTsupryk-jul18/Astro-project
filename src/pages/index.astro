// Comparison table: hardware register vs Checkbox digital register.
// A cell is either { text } (may contain <strong>/<br>) or { rows } (sub-items).
interface CompareListRow {
  label?: string;
  value: string;
  ok: boolean;
}
interface CompareCell {
  text?: string;
  rows?: CompareListRow[];
}
interface CompareRow {
  label: string;
  hw: CompareCell;
  cb: CompareCell;
}

const compareRows: CompareRow[] = [
  {
    label: "Початкова вартість каси",
    hw: {
      text: "15-50 тисяч гривень на старті.<br>Потім стільки же кожні 7 років.",
    },
    cb: { text: "0 гривень на старті.<br>Перший місяць — безкоштовно" },
  },
  {
    label: "Щомісячна вартість каси",
    hw: { text: "400-500 гривень / місяць" },
    cb: { text: "249 гривень / місяць <span class='muted'>(з ПДВ)</span>" },
  },
  {
    label: "Швидкість старту",
    hw: { text: "Щонайменше декілька днів" },
    cb: { text: "Декілька хвилин" },
  },
  {
    label: "Обсяг рутини",
    hw: {
      rows: [
        { label: "Відкриття-закриття зміни", value: "Ручне", ok: false },
        { label: "Облік товарів", value: "Паперовий/Ручний", ok: false },
        { label: "Формування z-звітів", value: "Ручне", ok: false },
      ],
    },
    cb: {
      rows: [
        { label: "Відкриття-закриття зміни", value: "Автоматичне", ok: true },
        { label: "Облік товарів", value: "Автоматичний", ok: true },
        { label: "Формування z-звітів", value: "Автоматичне", ok: true },
      ],
    },
  },
  {
    label: "Обслуговування",
    hw: {
      rows: [
        { value: "Регулярні поїздки у сервісний центр", ok: false },
        { value: "Пломбування", ok: false },
        { value: "Заміна паперу", ok: false },
      ],
    },
    cb: {
      text: "Каса просто працює — без поїздок, витратних матеріалів і сервісних центрів.",
    },
  },
  {
    label: "Контроль",
    hw: { text: "Потрібно фізично їхати<br>на торгову точку, щоб перевірити." },
    cb: {
      text: "Всі продажі, чеки та звіти<br>в реальному часі <strong>в онлайн-кабінеті.</strong>",
    },
  },
  {
    label: "Доступність",
    hw: { text: "Потрібно знаходитися фізично<br>на торговій точці." },
    cb: {
      text: "<strong>Працює</strong> на смартфоні,<br>комп'ютері чи планшеті.",
    },
  },
  {
    label: "Інтеграції",
    hw: {
      text: "Ви обмежені у виборі облікових систем і POS-обладнання, які ще й потребують складного підключення.",
    },
    cb: {
      text: "З'єднуйте касу з улюбленою обліковою системою та POS-терміналом <strong>за лічені хвилини.</strong>",
    },
  },
  {
    label: "Масштабування",
    hw: {
      text: "Вартість та складність обслуговування <strong>зростає в прогресії</strong> з кожною новою касою.",
    },
    cb: {
      text: "<strong>Легко адаптуйтеся</strong> під потреби бізнесу — додавайте та прибирайте каси <strong>за кілька кліків.</strong>",
    },
  },
];

const features = [
  {
    image: $image("/feature-1@2x.png"),
    width: 393,
    height: 84,
    theme: "light",
    title: "Підвищуйте ефективність",
    text: "Чекбокс <strong>легко вбудовується</strong> в бізнес-процеси: зменшить навантаження на співробітників та головний біль керівників.",
  },
  {
    image: $image("/feature-2@2x.png"),
    width: 309,
    height: 76,
    theme: "light",
    title: "Приборкайте ризики",
    text: "<strong>Чекбокс зареєструє кожен</strong> чек у податковій, відповідаючи усім вимогам держави.",
  },
  {
    image: $image("/feature-3@2x.png"),
    width: 399,
    height: 76,
    theme: "dark",
    title: "Контролюйте",
    text: "З Чекбоксом всі дані про каси та чеки завжди у вас на кінчиках пальців. У реальному часі, <strong>коли вам зручно та де вам зручно.</strong>",
  },
];

// "How it works" — 4 onboarding steps; each card animates its own mini-UI,
// and the cards play one after another (see the master timeline in <script>).
const stepRegisterFields = [
  { label: "Ім'я та прізвище", value: "Іваненко Олексій" },
  { label: "Email", value: "info@mybusiness.ua" },
];
const stepSetupFields = [
  { label: "Назва каси", value: "Каса №1" },
  { label: "Торгова точка", value: "Пр. Миру, 14" },
  { label: "Тип", value: "Програмний РРО" },
];
const stepCatalogItems = [
  { name: "Кава", price: "75 ₴", dot: "#8a5a44" },
  { name: "Піца Маргарита", price: "180 ₴", dot: "#e0a100" },
  { name: "Вода 0.5л", price: "25 ₴", dot: "#3f6fd1" },
];
const stepReceiptItems = [
  { name: "Кава", qty: "1 шт", price: "75 ₴" },
  { name: "Круасан", qty: "2 шт", price: "90 ₴" },
];

// Client cases slider. A slide is either a quote (author + role) or a
// note — a short highlight in a dashed box (see the INTERTOP card).
interface Slide {
  image: ImageMetadata;
  label: string;
  text: string;
  author?: string;
  role?: string;
  note?: boolean;
}

const slides: Slide[] = [
  {
    image: $image("/slide-1.png"),
    label: "Glovo",
    text: "Поки процес внесення товарів в чек був неавтоматизованим, виникала маса розбіжностей між замовленням і товарами, які вносилися в фіскальний чек вручну. Система, побудована з Checkbox, забезпечує 100% відповідність замовлення і товарів, внесених в чек.",
    author: "Катерина Нестеренко",
    role: "Glovo Accounting Lead",
  },
  {
    image: $image("/slide-2.png"),
    label: "Фокстрот",
    text: "Важливо, що керування кількістю кас дуже зручне і швидке. Процес зняття з реєстрації та реєстрація нової каси займає кілька хвилин. Це нам дозволило вчасно реагувати на нові виклики, оскільки з початку війни дуже швидко змінювалась кількість працюючих магазинів.",
    author: "Василь Гриб",
    role: "Начальник відділу технічної підтримки продажів мережі Фокстрот",
  },
  {
    image: $image("/slide-3.png"),
    label: "ЛЮКСОПТИКА",
    text: "Ми дуже вдячні компанії Checkbox за крутий експірієнс, який зараз маємо. Ми завжди прагнемо надавати найкраще нашим клієнтам, завжди прагнемо інновацій. І коли можемо щось спростити для кінцевого споживача, для наших співробітників, ще й зекономивши гроші – це кайфово.",
    author: "Дмитро Сергієнко",
    role: "ІТ-директор (CIO) компанії Люксоптика",
  },
  {
    image: $image("/slide-4.png"),
    label: "HappyTime",
    text: "Вивчала, багато читала, дивилася на досвід колег-підприємців і вирішила спробувати Checkbox, адже було зрозуміло, що це найзручніша програма.",
    author: "Тетяна Полікарпова",
    role: "Власниця магазину HappyTime",
  },
  {
    image: $image("/slide-5.png"),
    label: "INTERTOP",
    text: "Мережа INTERTOP стала першим великим бізнесом України, який відмовився від усіх залізних кас і перейшов на ПРРО Checkbox.",
    note: true,
  },
