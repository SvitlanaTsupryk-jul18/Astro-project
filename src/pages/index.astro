      </p>
      <p class="compare-colhead compare-colhead--cb">
        <svg viewBox="0 0 32 32" fill="currentColor" width="14" height="14"
          ><path
            d="M31.94 31.94H0V0h31.94v31.94ZM5.32 5.32v21.3h21.3V5.32H5.32Z"
          ></path><path d="M9.32 9.32h13.3v13.3L9.32 9.32Z"></path></svg
        > Цифрова каса Чекбоксу
      </p>

      {
        compareRows.map((row, i) => (
          <div class="compare-row" style={`--r:${i + 2}`}>
            <div class="compare-rowhead">
              <span class="compare-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="compare-label">{row.label}</span>
            </div>

            {[
              { cell: row.hw, kind: "hw", head: "Апаратні касові апарати" },
              { cell: row.cb, kind: "cb", head: "Цифрова каса Чекбоксу" },
            ].map(({ cell, kind, head }) => (
              <div class={`compare-cell compare-cell--${kind}`}>
                <p class="compare-cell-head">
                  {kind === "hw" ? (
                    <svg
                      viewBox="0 0 16 16"
                      fill="currentColor"
                      width="12"
                      height="12"
                    >
                      <path d="M14 2H2L14 14V2Z" />
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 32 32"
                      fill="currentColor"
                      width="14"
                      height="14"
                    >
                      <path d="M31.94 31.94H0V0h31.94v31.94ZM5.32 5.32v21.3h21.3V5.32H5.32Z" />
                      <path d="M9.32 9.32h13.3v13.3L9.32 9.32Z" />
                    </svg>
                  )}
                  {head}
                </p>

                <div class="compare-cell-body">
                  {cell.text ? (
                    <p class="compare-val" set:html={cell.text} />
                  ) : (
                    <ul class="compare-list">
                      {cell.rows?.map((r) => (
                        <li
                          class:list={[
                            "compare-list-item",
                            { "has-label": r.label },
