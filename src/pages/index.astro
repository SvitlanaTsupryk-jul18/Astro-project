---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import girlImage from "../assets/images/girl.png";
---

<BaseLayout
  title="ПРРО Checkbox | Програмний РРО № 1 для бізнесу в Україні"
  description="Офіційний вебсайт Checkbox - програмного РРО для вашого бізнесу ✅ Безкоштовний 1 місяць користування ⏩ Швидка та зручна реєстрація через електронний кабінет."
  ogImage="/static/images/mainPage/og.png"
  ogType="website"
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="hero__stat">Чекбокс видав <strong>2 582 509 485</strong> чеків</p>
        <h1 class="hero__title">Впевненість<br />у кожному чеку</h1>
        <p class="hero__desc">Тримайте каси під контролем і зосереджуйтесь на продажах, замість бюрократії. З найбільшим провайдером цифрових кас (ПРРО) в Україні.</p>
        <div class="hero__actions">
          <a href="https://my.checkbox.ua/auth/registration" class="btn btn--primary">
            Почніть безкоштовно
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="#" class="btn btn--outline">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Запишіться на демо
          </a>
        </div>
      </div>
      <div class="hero__media">
        <div class="hero__pattern" aria-hidden="true"></div>
        <Image src={girlImage} alt="Клієнтка Checkbox у футболці з логотипом компанії" class="hero__image" fetchpriority="high" loading="eager" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: #f5f2f9;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 40px;
    padding: 64px 0;
  }

  .hero__stat {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #52525b;
    border-bottom: 1px dotted #a1a1aa;
    padding-bottom: 10px;
    margin-bottom: 24px;
  }

  .hero__stat strong {
    font-size: 0.95rem;
    font-weight: 800;
    color: #18181b;
  }

  .hero__title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #18181b;
    margin: 0 0 24px;
  }

  .hero__desc {
    font-size: 1.05rem;
    line-height: 1.6;
    color: #3f3f46;
    max-width: 480px;
    margin: 0 0 32px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .btn svg {
    width: 18px;
    height: 18px;
  }

  .btn:hover {
    opacity: 0.85;
  }

  .btn--primary {
    background: #8f257d;
    color: #fff;
  }

  .btn--outline {
    border: 1.5px solid #18181b;
    color: #18181b;
  }

  .hero__media {
    position: relative;
  }

  .hero__image {
    position: relative;
    z-index: 1;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding: 40px 0;
    }

    .hero__title {
      font-size: 40px;
    }

    .hero__media {
      order: -1;
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>
