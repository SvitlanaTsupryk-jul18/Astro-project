// Grab every logo in the companies folder in one glob (the pattern must be a
// literal string — Vite resolves it at build time), sort filenames numerically
// so Cont-2 comes before Cont-10, then pair each image with a name for its alt.
const companyLogoModules = import.meta.glob<ImageMetadata>(
  "/src/assets/images/companies/*.{png,jpg,jpeg,svg,webp}",
  { eager: true, import: "default" }
);
const companyLogos = Object.entries(companyLogoModules)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([, src], i) => ({ src, alt: companiesNames[i] ?? "" }));

const courierStops = [
  { address: "Шевченка, 12", time: "10:24", done: true },
  { address: "Личаківська, 48", time: "11:05", done: false },
  { address: "Стрийська, 88", time: "12:10", done: false },
  { address: "Зелена, 24", time: "13:30", done: false },
  { address: "Тичини, 12", time: "14:07", done: false },
];

const postShipments = [
  {
    ttn: "TTN 720 4198 3221",
    carrier: "Нова пошта",
    amount: "1 240 ₴",
    status: "Доставлено",
  },
  {
    ttn: "TTN 110 5521 2144",
    carrier: "Нова пошта",
    amount: "685 ₴",
    status: "Фіскалізовано",
  },
  {
    ttn: "TTN 7000 1021 6230",
    carrier: "Нова пошта",
    amount: "2 199 ₴",
    status: "В дорозі",
