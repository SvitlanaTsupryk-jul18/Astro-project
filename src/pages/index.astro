  <section class="news">
    <div class="container">
      <p class="subtitle">Актуальне</p>
      <h2 class="news-title">Новини компанії</h2>
      <ul class="news-list">
        {
          newsPosts.map((post) => (
            <li>
              <a class="news-card" href="/blog/">
                <span class="news-tag">{post.category}</span>
                <h3 class="news-card-title">{post.title}</h3>
                <p class="news-author">{post.author}</p>
                <p class="news-meta">
                  {post.date}
                  <span class="news-read">{post.readTime}</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
