          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 14v-2a8 8 0 0 1 16 0v2"></path><rect
            x="2"
            y="14"
