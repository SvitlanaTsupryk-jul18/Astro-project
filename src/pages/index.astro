  <section class="compare">
    <div class="container compare-head-wrap">
      <p class="subtitle">Чому нас обирають</p>
      <h2 class="compare-title">
        Цифрова каса Чекбоксу<br />втричі дешевша, простіша<br />і зручніша за
        апаратний РРО
      </h2>
    </div>

    <div class="container compare-grid">
      <!-- Desktop-only white highlight behind the Checkbox column -->
      <div
        class="compare-highlight"
        aria-hidden="true"
        style={`grid-row: 1 / span ${compareRows.length + 1}`}
      >
      </div>

      <!-- Desktop-only column headers (row 1) -->
      <p class="compare-colhead compare-colhead--hw">
        <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"
          ><path d="M14 2H2L14 14V2Z"></path></svg
