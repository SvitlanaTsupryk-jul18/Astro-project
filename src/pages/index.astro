  const testimonialsSection =
  document.querySelector<HTMLElement>(".testimonials");
if (testimonialsSection) {
  const track = testimonialsSection.querySelector<HTMLElement>(
    ".testimonials-track"
  )!;

  // ── Безкінечна стрічка: клонуємо перший і останній слайд ──
  const realCards = [
    ...track.querySelectorAll<HTMLElement>(".testimonials-card"),
  ];

  // Прибирає дублікати id всередині inline SVG (defs/gradient/clipPath),
  // щоб клони не ламали посилання url(#...) / href="#..."
  const dedupeIds = (root: HTMLElement) => {
    const suffix = `-clone-${Math.random().toString(36).slice(2, 8)}`;
    root.querySelectorAll<HTMLElement>("[id]").forEach((el) => {
      const oldId = el.id;
      const newId = oldId + suffix;
      el.id = newId;
      root
        .querySelectorAll(`[fill="url(#${oldId})"]`)
        .forEach((ref) => ref.setAttribute("fill", `url(#${newId})`));
      root
        .querySelectorAll(`[href="#${oldId}"]`)
        .forEach((ref) => ref.setAttribute("href", `#${newId}`));
    });
  };

  const hasLoop = realCards.length > 1;

  if (hasLoop) {
    const firstClone = realCards[0].cloneNode(true) as HTMLElement;
    const lastClone = realCards[realCards.length - 1].cloneNode(
      true
    ) as HTMLElement;

    [firstClone, lastClone].forEach((clone) => {
      clone.classList.add("is-clone");
      clone.setAttribute("aria-hidden", "true");
      clone
        .querySelectorAll<HTMLElement>("a, button")
        .forEach((el) => el.setAttribute("tabindex", "-1"));
      dedupeIds(clone);
    });

    track.insertBefore(lastClone, realCards[0]);
    track.appendChild(firstClone);
  }

  const cards = [
    ...track.querySelectorAll<HTMLElement>(".testimonials-card"),
  ];
  const bodies = cards.map(
    (card) => card.querySelector<HTMLElement>(".testimonials-body")!
  );
  const prevBtn = testimonialsSection.querySelector<HTMLButtonElement>(
    ".slider-btn--prev"
  )!;
  const nextBtn = testimonialsSection.querySelector<HTMLButtonElement>(
    ".slider-btn--next"
  )!;

  const desktop = window.matchMedia("(min-width: 1024px)");
  const PAD_ACTIVE = 16;
  const BODY_MARGIN = { top: 24, right: 40, bottom: 24, left: 24 };
  const ACTIVE_SHARE = 0.65;

  // Реальний перший/останній слайд у новому, "розширеному" масиві cards
  const FIRST_REAL = hasLoop ? 1 : 0;
  const LAST_REAL = hasLoop ? cards.length - 2 : cards.length - 1;

  let index = FIRST_REAL;
  let bodyW = 0;
  let step = 0;
  let isAnimating = false;

  const cardProps = (active: boolean) => ({
    padding: active ? PAD_ACTIVE : 16,
    backgroundColor: active ? "#ffffff" : "rgba(255,255,255,0)",
    borderColor: active ? "rgba(255,255,255,0)" : "rgba(255,255,255,0.35)",
  });
  const bodyProps = (active: boolean) => ({
    width: active ? bodyW : 0,
    marginTop: active ? BODY_MARGIN.top : 0,
    marginRight: active ? BODY_MARGIN.right : 0,
    marginBottom: active ? BODY_MARGIN.bottom : 0,
    marginLeft: active ? BODY_MARGIN.left : 0,
    autoAlpha: active ? 1 : 0,
  });

  const measure = () => {
    if (!desktop.matches) return;
    const mediaW = cards[0].querySelector<HTMLElement>(
      ".testimonials-media"
    )!.offsetWidth;
    const containerW = track.parentElement!.clientWidth;
    bodyW = Math.max(
      240,
      Math.round(containerW * ACTIVE_SHARE) -
        (PAD_ACTIVE * 2 + BODY_MARGIN.left + BODY_MARGIN.right + mediaW)
    );
    testimonialsSection.style.setProperty("--body-w", `${bodyW}px`);
    for (let k = 0; k < cards.length - 1; k++) {
      if (k !== index && k + 1 !== index) {
        step = cards[k + 1].offsetLeft - cards[k].offsetLeft;
        break;
      }
    }
  };

  // apply() тепер приймає onDone — колбек, що спрацює
  // одразу (instant) або по завершенню анімації треку (animate)
  const apply = (animate: boolean, onDone?: () => void) => {
    const instant = reducedMotion || !animate;
    const tween: gsap.TweenVars = {
      duration: 1,
      ease: "expo.inOut",
      overwrite: true,
    };

    if (desktop.matches) {
      cards.forEach((card, k) => {
        const active = k === index;
        if (instant) {
          gsap.set(card, cardProps(active));
          gsap.set(bodies[k], bodyProps(active));
        } else {
          gsap.to(card, { ...cardProps(active), ...tween });
          gsap.to(bodies[k], { ...bodyProps(active), ...tween });
        }
      });
      const x = -index * step;
      if (instant) {
        gsap.set(track, { x });
      } else {
        gsap.to(track, { x, ...tween, onComplete: onDone });
      }
    } else {
      const x = -(cards[index].offsetLeft - cards[0].offsetLeft);
      if (instant) {
        gsap.set(track, { x });
      } else {
        gsap.to(track, { x, ...tween, onComplete: onDone });
      }
    }

    cards.forEach((card, k) =>
      card.classList.toggle("is-current", k === index)
    );

    if (instant) onDone?.();
  };

  const goTo = (i: number, animate = true) => {
    console.log(i, index);
    if (isAnimating) return;
    index = i;

    const finalize = () => {
      // Проскочили за клон останньої картки назад → миттєво
      // перескакуємо на справжню останню (виглядає ідентично)
      if (hasLoop && index === 0) {
        index = LAST_REAL;
        apply(false);
      }
      // Проскочили за клон першої картки вперед → миттєво
      // перескакуємо на справжню першу
      else if (hasLoop && index === cards.length - 1) {
        index = FIRST_REAL;
        apply(false);
      }
      isAnimating = false;
    };

    if (animate && !reducedMotion) isAnimating = true;
    apply(animate, finalize);
  };

  const init = () => {
    apply(false);
    measure();
    apply(false);
  };

  prevBtn.addEventListener("click", () => goTo(index - 1));
  nextBtn.addEventListener("click", () => goTo(index + 1));

  cards.forEach((card, k) =>
    card.addEventListener("click", () => {
      if (desktop.matches && k !== index && !isAnimating) goTo(k);
    })
  );

  let touchX = 0;
  track.addEventListener(
    "touchstart",
    (e) => (touchX = e.touches[0].clientX),
    { passive: true }
  );
  track.addEventListener(
    "touchend",
    (e) => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 40) goTo(index + (dx < 0 ? 1 : -1));
    },
    { passive: true }
  );

  resizeHandlers.push(() => {
    gsap.set([track, ...cards, ...bodies], { clearProps: "all" });
    init();
  });

  init();

  if (!reducedMotion) {
    gsap.set(cards, { y: 48, autoAlpha: 0 });
    const introObserver = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        introObserver.disconnect();
        gsap.to(cards, {
          y: 0,
          autoAlpha: 1,
          duration: 0.9,
          ease: "power3.out",
          stagger: 0.12,
        });
      },
      { threshold: 0.2 }
    );
    introObserver.observe(track);
  }
}

  // API //
  const apiFlow = document.querySelector(".api-flow");
  if (apiFlow) {
    const apiNodes = [
      ...apiFlow.querySelectorAll(".api-node, .api-card, .api-row, .api-logo"),
    ];
    const clearApi = () =>
      apiNodes.forEach((n) => n.classList.remove("is-active"));

    if (reducedMotion) {
      apiNodes.forEach((n) => n.classList.add("is-active"));
    } else {
      const apiTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 1.8,
        paused: true,
      });
      apiTl.call(clearApi);
      apiNodes.forEach((n) => {
        apiTl.call(() => n.classList.add("is-active"), [], "+=.7");
      });

      loops.set(apiFlow, apiTl);
    }
  }

  // Category slider: tabs auto-advance one by one (paused via loops/
  // loopObserver below, same as the API flow); any manual click on a tab or
  // arrow jumps straight to that slide and stops the autoplay for good.
  const categorySection = document.querySelector<HTMLElement>(".category");
  if (categorySection) {
    const tabs = [
      ...categorySection.querySelectorAll<HTMLButtonElement>(".category-tab"),
    ];
    const panelMedia = categorySection.querySelector<HTMLElement>(
      ".category-panel-media"
    )!;
    const panelImage = categorySection.querySelector<HTMLImageElement>(
      ".category-panel-image"
    )!;
    const panelText = categorySection.querySelector<HTMLElement>(
      ".category-panel-text"
    )!;
    const panelAuthorName = categorySection.querySelector<HTMLElement>(
      ".category-panel-author-name"
    )!;
    const panelRole = categorySection.querySelector<HTMLElement>(
      ".category-panel-role"
    )!;
    const panelLogos = categorySection.querySelector<HTMLElement>(
      ".category-panel-logos"
    )!;
    const prevBtn = categorySection.querySelector<HTMLButtonElement>(
      ".slider-btn--prev"
    )!;
    const nextBtn = categorySection.querySelector<HTMLButtonElement>(
      ".slider-btn--next"
    )!;

    let index = Math.max(
      0,
      tabs.findIndex((tab) => tab.classList.contains("is-active"))
    );
    let categoryTl: gsap.core.Timeline | undefined;

    const render = () => {
      const tab = tabs[index];
      const { image, srcset, imageW, imageH, quote, author, role, logos } =
        tab.dataset;
      panelImage.src = image!;
      panelImage.srcset = srcset ?? "";
      panelImage.width = Number(imageW);
      panelImage.height = Number(imageH);
      panelText.textContent = quote!;
      panelAuthorName.textContent = author!;
      panelRole.textContent = role!;
      panelLogos.innerHTML = "";
      logos!.split("|").forEach((label) => {
        const li = document.createElement("li");
        li.textContent = label;
        panelLogos.append(li);
      });
    };

    const activate = (next: number, userTriggered = false) => {
      index = (next + tabs.length) % tabs.length;
      tabs.forEach((tab, k) => {
        const active = k === index;
        tab.classList.toggle("is-active", active);
        tab.setAttribute("aria-selected", String(active));
      });
      tabs[index].scrollIntoView({
        behavior: reducedMotion ? "auto" : "smooth",
        inline: "center",
        block: "nearest",
      });

      if (reducedMotion) {
        render();
      } else {
        gsap.to(panelMedia, {
          autoAlpha: 0,
          duration: 0.25,
          ease: "power1.in",
          overwrite: "auto",
          onComplete: () => {
            render();
            gsap.to(panelMedia, {
              autoAlpha: 1,
              duration: 0.35,
              ease: "power1.out",
              overwrite: "auto",
            });
          },
        });
      }

      if (userTriggered) {
        categoryTl?.pause();
        loops.delete(categorySection);
      }
    };

    tabs.forEach((tab, i) =>
      tab.addEventListener("click", () => activate(i, true))
    );
    prevBtn.addEventListener("click", () => activate(index - 1, true));
    nextBtn.addEventListener("click", () => activate(index + 1, true));

    if (!reducedMotion) {
      categoryTl = gsap.timeline({ repeat: -1, paused: true });
      categoryTl.call(() => activate(index + 1), [], 4);
      loops.set(categorySection, categoryTl);
    }
  }

  if (loops.size) {
    const loopObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const timeline = loops.get(entry.target);
          if (!timeline) return;
          entry.isIntersecting ? timeline.play() : timeline.pause();
        });
      },
      { threshold: 0.3 }
    );
    loops.forEach((_, el) => loopObserver.observe(el));
  }

  // FAQ: <details> can't animate natively, so the summary click is
  // intercepted and the answer is tweened by GSAP (it can animate height to
  // "auto"); [open] is only removed after the collapse finishes
  document
    .querySelectorAll<HTMLDetailsElement>(".faq-item")
    .forEach((details) => {
      const summary = details.querySelector("summary")!;
      const content = details.querySelector<HTMLElement>(".faq-content")!;
      const wrap = details.closest(".faq-item-wrap");

      summary.addEventListener("click", (e) => {
        e.preventDefault();
        // is-open (not details.open) drives the toggle: [open] stays set
        // until the collapse tween finishes, so a click mid-collapse should
        // reopen, tweening from the current height
        const isOpen = details.classList.contains("is-open");

        if (!isOpen) {
          wrap?.classList.add("is-open");
          details.classList.add("is-open");
          if (!details.open) {
            details.open = true;
            gsap.set(content, {
              height: 0,
              opacity: 0,
              marginTop: 0,
              overflow: "hidden",
            });
          }
          gsap.to(content, {
            height: "auto",
            opacity: 1,
            marginTop: 16,
            duration: 0.2,
            ease: "power1.out",
            overwrite: true,
            clearProps: "all",
          });
        } else {
          wrap?.classList.remove("is-open");
          details.classList.remove("is-open");
          gsap.to(content, {
            height: 0,
            opacity: 0,
            marginTop: 0,
            overflow: "hidden",
            duration: 0.2,
            ease: "power1.in",
            overwrite: true,
            onComplete: () => {
              details.open = false;
              gsap.set(content, { clearProps: "all" });
            },
          });
        }
      });
    });
</script>
