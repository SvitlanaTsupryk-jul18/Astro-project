---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import girlImage from "@assets/images/girl@2x.png";
import ArrowRight from "@assets/icons/arrow-right.svg";
import reason1Image from "@assets/images/reason-1.png";

import { $image } from "@utils/assets";
import "@styles/pages/index.css";

// Client logos for the ticker — each paired with its company name (alt)
const clientLogos = [
  { src: $image("/choices/logo-1.svg"), alt: "Компанія 1" },
  { src: $image("/choices/logo-2.svg"), alt: "Компанія 2" },
  { src: $image("/choices/logo-3.svg"), alt: "Компанія 3" },
  { src: $image("/choices/logo-4.svg"), alt: "Компанія 4" },
  { src: $image("/choices/logo-5.svg"), alt: "Компанія 5" },
  { src: $image("/choices/logo-6.svg"), alt: "Компанія 6" },
  { src: $image("/choices/logo-7.svg"), alt: "Компанія 7" },
  { src: $image("/choices/logo-8.svg"), alt: "Компанія 8" },
  { src: $image("/choices/logo-9.svg"), alt: "Компанія 9" },
  { src: $image("/choices/logo-10.svg"), alt: "Компанія 10" },
  { src: $image("/choices/logo-11.svg"), alt: "Компанія 11" },
  { src: $image("/choices/logo-12.svg"), alt: "Компанія 12" },
];

// Statistics cards
const stats = [
  {
    icon: $image("/st-1.svg"),
    value: "100+ МЛН",
    caption: "чеків видаємо щомісяця",
  },
  { icon: $image("/st-2.svg"), value: "240+ ТИС", caption: "активних кас" },
  {
    icon: $image("/st-3.svg"),
    value: "38%",
    caption: "ПРРО реєструються на Чекбокс",
  },
  {
    icon: $image("/st-4.svg"),
    value: "740+ МЛРД",
    caption: "гривень виторгу в 2025",
  },
];

// "Why choose us" bento section
const integrationNames = [
  "SoloMono",
  "Rozetka",
  "Prom",
  "Епіцентр",
  "Servio",
  "Хорошоп",
  "Firemenu",
  "Uspacy",
  "BeautyPro",
  "DentaPro",
  "Shopify",
  "WooCommerce",
  "BubiBo",
  "Hotelms",
  "KeepinCRM",
  "Друк",
  "InstaSport",
  "Sitniks",
  "Sender",
  "iPay.ua",
  "KeyCRM",
  "Perfectum",
  "Odoo",
  "Мед Інфо Сервіс",
  "PawnShop",
  "Posman",
  "Ordo",
  "OpenCart",
  "Poster",
  "Quincefin",
  "Integrica",
  "RoApp",
  "RCRM",
  "ShopExpress",
  "ClinicCards",
  "WLaunch",
  "Oppointer",
  "Webasyst",
  "SmartFin-UA",
  "EasyWeek",
  "Vortex",
];

const courierStops = [
  { address: "Шевченка, 12", time: "10:24", done: true },
  { address: "Личаківська, 48", time: "11:05", done: false },
  { address: "Стрийська, 88", time: "12:10", done: false },
  { address: "Зелена, 24", time: "13:30", done: false },
  { address: "Тичини, 12", time: "14:07", done: false },
];

const postShipments = [
  {
    ttn: "TTN 720 4198 3221",
    carrier: "Нова пошта",
    amount: "1 240 ₴",
    status: "Доставлено",
  },
  {
    ttn: "TTN 110 5521 2144",
    carrier: "Нова пошта",
    amount: "685 ₴",
    status: "Фіскалізовано",
  },
  {
    ttn: "TTN 7000 1021 6230",
    carrier: "Нова пошта",
    amount: "2 199 ₴",
    status: "В дорозі",
  },
];

// Comparison table: hardware register vs Checkbox digital register.
// A cell is either { text } (may contain <strong>/<br>) or { rows } (sub-items).
interface CompareListRow {
  label?: string;
  value: string;
  ok: boolean;
}
interface CompareCell {
  text?: string;
  rows?: CompareListRow[];
}
interface CompareRow {
  label: string;
  hw: CompareCell;
  cb: CompareCell;
}

const compareRows: CompareRow[] = [
  {
    label: "Початкова вартість каси",
    hw: {
      text: "15-50 тисяч гривень на старті.<br>Потім стільки же кожні 7 років.",
    },
    cb: { text: "0 гривень на старті.<br>Перший місяць — безкоштовно" },
  },
  {
    label: "Щомісячна вартість каси",
    hw: { text: "400-500 гривень / місяць" },
    cb: { text: "249 гривень / місяць <span class='muted'>(з ПДВ)</span>" },
  },
  {
    label: "Швидкість старту",
    hw: { text: "Щонайменше декілька днів" },
    cb: { text: "Декілька хвилин" },
  },
  {
    label: "Обсяг рутини",
    hw: {
      rows: [
        { label: "Відкриття-закриття зміни", value: "Ручне", ok: false },
        { label: "Облік товарів", value: "Паперовий/Ручний", ok: false },
        { label: "Формування z-звітів", value: "Ручне", ok: false },
      ],
    },
    cb: {
      rows: [
        { label: "Відкриття-закриття зміни", value: "Автоматичне", ok: true },
        { label: "Облік товарів", value: "Автоматичний", ok: true },
        { label: "Формування z-звітів", value: "Автоматичне", ok: true },
      ],
    },
  },
  {
    label: "Обслуговування",
    hw: {
      rows: [
        { value: "Регулярні поїздки у сервісний центр", ok: false },
        { value: "Пломбування", ok: false },
        { value: "Заміна паперу", ok: false },
      ],
    },
    cb: {
      text: "Каса просто працює — без поїздок, витратних матеріалів і сервісних центрів.",
    },
  },
  {
    label: "Контроль",
    hw: { text: "Потрібно фізично їхати<br>на торгову точку, щоб перевірити." },
    cb: {
      text: "Всі продажі, чеки та звіти<br>в реальному часі <strong>в онлайн-кабінеті.</strong>",
    },
  },
  {
    label: "Доступність",
    hw: { text: "Потрібно знаходитися фізично<br>на торговій точці." },
    cb: {
      text: "<strong>Працює</strong> на смартфоні,<br>комп'ютері чи планшеті.",
    },
  },
  {
    label: "Інтеграції",
    hw: {
      text: "Ви обмежені у виборі облікових систем і POS-обладнання, які ще й потребують складного підключення.",
    },
    cb: {
      text: "З'єднуйте касу з улюбленою обліковою системою та POS-терміналом <strong>за лічені хвилини.</strong>",
    },
  },
  {
    label: "Масштабування",
    hw: {
      text: "Вартість та складність обслуговування <strong>зростає в прогресії</strong> з кожною новою касою.",
    },
    cb: {
      text: "<strong>Легко адаптуйтеся</strong> під потреби бізнесу — додавайте та прибирайте каси <strong>за кілька кліків.</strong>",
    },
  },
];

// Stacking cards ("Касуйте впевнено")
// width/height = the @2x file's intrinsic size ÷ 2 (its real 1x display size);
// combined with densities={[1, 2]} below, Astro generates both a 1x and a 2x
// srcset entry instead of always shipping the full 2x file to every screen.
const features = [
  {
    image: $image("/feature-1@2x.png"),
    width: 393,
    height: 84,
    theme: "light",
    title: "Підвищуйте ефективність",
    text: "Чекбокс <strong>легко вбудовується</strong> в бізнес-процеси: зменшить навантаження на співробітників та головний біль керівників.",
  },
  {
    image: $image("/feature-2@2x.png"),
    width: 309,
    height: 76,
    theme: "light",
    title: "Приборкайте ризики",
    text: "<strong>Чекбокс зареєструє кожен</strong> чек у податковій, відповідаючи усім вимогам держави.",
  },
  {
    image: $image("/feature-3@2x.png"),
    width: 399,
    height: 76,
    theme: "dark",
    title: "Контролюйте",
    text: "З Чекбоксом всі дані про каси та чеки завжди у вас на кінчиках пальців. У реальному часі, <strong>коли вам зручно та де вам зручно.</strong>",
  },
];
---

<BaseLayout
  title="ПРРО Checkbox | Програмний РРО № 1 для бізнесу в Україні"
  description="Офіційний вебсайт Checkbox - програмного РРО для вашого бізнесу ✅ Безкоштовний 1 місяць користування ⏩ Швидка та зручна реєстрація через електронний кабінет."
  ogImage="/static/images/mainPage/og.png"
  ogType="website"
>
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-stat">
          Чекбокс видав <b>2 582 509 485</b> чеків
        </p>
        <h1>Впевненість<br />у кожному чеку</h1>
        <p class="hero-desc">
          Тримайте каси під контролем і зосереджуйтесь на продажах,<br /> замість
          бюрократії. <strong
            >З найбільшим провайдером цифрових кас<br /> (ПРРО) в Україні.</strong
          >
        </p>
        <div class="hero-actions">
          <a href="https://my.checkbox.ua/auth/registration" class="btn">
            Почніть безкоштовно
            <ArrowRight />
          </a>
          <a href="#" class="btn btn--outline">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
            >
              <path
                d="M10.8346 15V16.6667H14.168V18.3333H5.83464V16.6667H9.16797V15H2.5013C2.04107 15 1.66797 14.6269 1.66797 14.1667V3.33333C1.66797 2.8731 2.04107 2.5 2.5013 2.5H17.5013C17.9616 2.5 18.3346 2.8731 18.3346 3.33333V14.1667C18.3346 14.6269 17.9616 15 17.5013 15H10.8346ZM3.33464 4.16667V13.3333H16.668V4.16667H3.33464ZM8.33464 6.25L12.5013 8.75L8.33464 11.25V6.25Z"
                fill="black"></path>
            </svg>
            Запишіться на демо
          </a>
        </div>
      </div>
      <div class="hero-image">
        <!-- <div class="hero-pattern" aria-hidden="true"></div> -->
        <Image
          src={girlImage}
          width={952}
          height={575}
          densities={[1, 2]}
          alt="Клієнтка Checkbox у футболці з логотипом компанії"
          fetchpriority="high"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="choice">
    <div class="container">
      <h2 class="subtitle">Провідні компанії обирають Чекбокс</h2>
      <p>12+ Галузей • 220 000+ бізнесів</p>
    </div>
    <div class="choice-wrapper">
      <div class="choice-content">
        {
          [...clientLogos, ...clientLogos].map((logo) => (
            <span class="choice-item">
              <Image src={logo.src} alt={logo.alt} class="choice-logo" />
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container statistic">
    <h2 hidden>Statistic</h2>
    {
      stats.map((item, i) => (
        <article class="statistic-card">
          <p class="statistic-index">{String(i + 1).padStart(2, "0")} —</p>
          <Image
            src={item.icon}
            alt="icon"
            class="statistic-icon"
            loading="lazy"
          />
          <p class="statistic-value">{item.value}</p>
          <h3 class="statistic-caption">{item.caption}</h3>
        </article>
      ))
    }
  </section>

  <section class="features">
    <div class="features-track">
      <div class="container features-inner">
        <div class="features-left">
          <p class="subtitle">Касова дисципліна без зусиль</p>
          <h2>Касуйте<br />впевнено</h2>
          <p class="features-text">
            Тримайте каси під контролем і зосереджуйтесь на продажах, замість
            бюрократії. З найбільшим провайдером цифрових кас (ПРРО) в Україні.
          </p>
        </div>
        <div class="features-right" id="features-stack">
          {
            features.map((feature, i) => (
              <div class={`feature feature--${feature.theme}`} data-card={i}>
                <svg class="svg-border" aria-hidden="true">
                  <rect />
                </svg>
                <Image
                  src={feature.image}
                  width={feature.width}
                  height={feature.height}
                  densities={[1, 2]}
                  alt={feature.title}
                  class="feature-image"
                  loading="lazy"
                />
                <div class="feature-body">
                  <h3 class="feature-title">{feature.title}</h3>
                  <p class="feature-text" set:html={feature.text} />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="banner">
      <h2>
        <span
          >Ми подбаємо, щоб каси просто працювали,<br />
          а ви</span
        > сміливо займалися бізнесом
      </h2>
    </div>
  </section>

  <section class="reasons">
    <div class="reasons-head">
      <div class="container">
        <p class="subtitle">Чому нас обирають</p>
        <h2>
          Більше 200 000 бізнесів<br />обрали Чекбокс<br />не випадково
        </h2>
      </div>
    </div>

    <div class="reasons-grid">
      <div class="reasons-cell">
        <p class="reasons-text">
          <span>Масштабуємося разом із вашим бізнесом</span> — легко працювати як
          з 1 касою, так і з 10 000 кас.
        </p>
        <div class="reasons-wrapper" aria-hidden="true">
          <div>
            <div class="reasons-scale-card">
              <Image
                src={reason1Image}
                densities={[1, 2]}
                alt="Pos terminal"
                loading="lazy"
              />
            </div>
          </div>
          {
            [1.05, 1.1, 1.15].map((scale) => (
              <div class="reasons-scale-slot" style={`--scale: ${scale}`}>
                 <svg class="svg-border svg-border-4" aria-hidden="true">
                  <rect />
                </svg>
                <div class="reasons-scale-card">
                  <Image
                    src={reason1Image}
                    densities={[1, 2]}
                    alt="Pos terminal"
                    loading="lazy"
                  />
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Row 1 · Col 2: offline mode -->
      <div class="reasons-cell">
        <p class="reasons-text">
          Каса працює навіть без світла чи інтернету. <span>Маємо офлайн-режим із синхронізацією при відновленні зв'язку.</span>
        </p>
        <div class="reasons-offline">
          <div class="reasons-offline-head">
            <span><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="16" height="16" rx="8" fill="#FFA04C" fill-opacity="0.32"/>
              <path d="M7.37352 9.66L7.18352 7.28V5H8.80352V7.28L8.62352 9.66H7.37352ZM7.99352 12.13C7.48352 12.13 7.08352 11.75 7.08352 11.28V11.22C7.08352 10.77 7.48352 10.39 7.99352 10.39C8.49352 10.39 8.92352 10.77 8.92352 11.22V11.28C8.92352 11.75 8.49352 12.13 7.99352 12.13Z" fill="#BE5900"/>
              </svg>
            Офлайн режим</span>
            <span>Локальна черга • 4</span>
          </div>
          <ul class="reasons-offline-list">
            {
              /* Queue mock: JS moves is-done/is-syncing down the list on scroll */
              [
                { ttn: "01245789052", state: "is-done", badge: "Відправлено" },
                { ttn: "01245789053", state: "is-syncing", badge: "Синхронізація" },
                { ttn: "01245789053", state: "", badge: "У черзі" },
                { ttn: "01245789053", state: "", badge: "У черзі" },
              ].map((item) => (
                <li class={item.state}>
                  <svg class="svg-border svg-border-4" aria-hidden="true">
                    <rect />
                  </svg>
                  <span>#&nbsp;{item.ttn}</span>
                  <span class="reasons-badge">{item.badge}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Row 1 · Col 3: three short callouts -->
      <div class="reasons-cell reasons-cell--stack">
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z"></path></svg
          >
          <p><strong>Працюємо надійно</strong> під час пікових навантажень.</p>
        </div>
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z"></path></svg
          >
          <p>
            <strong>Працюємо швидко.</strong> Реєструємо чеки в середньому за 300
            мілісекунд.
          </p>
        </div>
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M4 4v6h6M20 20v-6h-6"></path><path
              d="M4.5 9a8 8 0 0 1 14.5-3.5M19.5 15a8 8 0 0 1-14.5 3.5"
            ></path></svg
          >
          <p>
            <strong>Миттєво оновлюємо продукт</strong> під зміни законів, щоб ви спали
            спокійно.
          </p>
        </div>
      </div>

      <!-- Row 2 · Col 1-2: integrations -->
      <div class="reasons-cell reasons-cell--wide">
        <p class="reasons-text">
          <strong>200+ готових інтеграцій</strong> з обліковими системами, терміналами
          та іншим POS-обладнанням.
        </p>
        <ul class="reasons-logos">
          {integrationNames.map((name) => <li>{name}</li>)}
        </ul>
      </div>

      <!-- Row 2 · Col 3: courier mode -->
      <div class="reasons-cell">
        <p class="reasons-text">
          <strong>Режим кур'єра.</strong> Ваші кур'єри зможуть бачити тільки замовлення
          згідно свого маршрутного листа та видавати чеки в момент їх доставки.
        </p>
        <ul class="reasons-timeline">
          {
            courierStops.map((stop) => (
              <li class:list={{ "is-done": stop.done }}>
                <span class="reasons-timeline-dot" />
                <span class="reasons-timeline-address">{stop.address}</span>
                <time>{stop.time}</time>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Row 3 · Col 1: three short callouts -->
      <div class="reasons-cell reasons-cell--stack">
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="4" width="20" height="14" rx="2"></rect><path
              d="M8 21h8M12 18v3"></path></svg
          >
          <p>
            <strong>Працюємо у вебі</strong> та на інших платформах: iOS, Android,
            Windows, Linux, macOS.
          </p>
        </div>
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><ellipse cx="12" cy="5" rx="8" ry="3"></ellipse><path
              d="M4 5v14c0 1.66 3.58 3 8 3s8-1.34 8-3V5M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3"
            ></path></svg
          >
          <p>
            <strong>Безкоштовно назавжди</strong> зберігаємо всі ваші дані в безпеці
            з резервним копіюванням.
          </p>
        </div>
        <div class="reasons-mini">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M8 3 4 7l4 4M16 3l4 4-4 4M14 3l-4 18"></path></svg
          >
          <p>
