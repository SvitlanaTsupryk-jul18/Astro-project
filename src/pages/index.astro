                        >
                          {r.label && (
                            <span class="compare-list-label">{r.label}</span>
                          )}
                          <span class="compare-list-value">
                            {r.ok ? (
                              <svg
                                class="compare-ic compare-ic--ok"
                                viewBox="0 0 16 16"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M3 8.5 6.5 12 13 4" />
                              </svg>
                            ) : (
                              <svg
                                class="compare-ic compare-ic--no"
                                viewBox="0 0 16 16"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                              >
                                <path d="M4 4l8 8M12 4l-8 8" />
                              </svg>
                            )}
                            {r.value}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from "gsap";

  // Reasons mocks: one infinite GSAP timeline — the terminals pop into the
  // slots, then the offline queue syncs row by row, hold, repeat.
  // The IntersectionObserver only plays/pauses it, so the loop never runs
  // while the row is off screen.
  const scaleBlock = document.querySelector(".reasons-wrapper");
  const queueItems = [...document.querySelectorAll(".reasons-offline-list li")];

  if (scaleBlock && queueItems.length) {
    const setQueueState = (li: Element, state: string, badgeText: string) => {
      li.classList.remove("is-syncing", "is-done");
      if (state) li.classList.add(state);
      li.querySelector(".reasons-badge")!.textContent = badgeText;
    };

    // Frame 1 of the mock: first row already sent, second one syncing
    const resetQueue = () => {
      setQueueState(queueItems[0], "is-done", "Відправлено");
      setQueueState(queueItems[1], "is-syncing", "Синхронізація");
      queueItems.slice(2).forEach((li) => setQueueState(li, "", "У черзі"));
    };

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      // No looping animation: show both mocks in their final state
      gsap.set(".reasons-scale-slot .reasons-scale-card", { scale: 1 });
      queueItems.forEach((li) => setQueueState(li, "is-done", "Відправлено"));
    } else {
      const tl = gsap.timeline({ repeat: -1, repeatDelay: 2, paused: true });

      tl.call(resetQueue)
        // 1. terminals pop into the slots one by one
        .fromTo(
          ".reasons-scale-slot .reasons-scale-card",
          { scale: 0 },
          { scale: 1, duration: 0.5, ease: "back.out(1.2)", stagger: 0.5 },
        );

      // 2. then the queue advances one row every 0.9s
      queueItems.slice(1).forEach((li, idx) => {
        tl.call(
          () => {
            setQueueState(li, "is-done", "Відправлено");
            const next = queueItems[idx + 2];
            if (next) setQueueState(next, "is-syncing", "Синхронізація");
          },
          [],
          idx === 0 ? "+=0.6" : "+=0.9",
        );
      });

      const observer = new IntersectionObserver(
        (entries) => (entries[0].isIntersecting ? tl.play() : tl.pause()),
        { threshold: 0.3 },
      );
      observer.observe(scaleBlock);
    }
  }
</script>
