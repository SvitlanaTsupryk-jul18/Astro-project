  <section class="faq">
    <div class="container faq-inner">
      <p class="subtitle">FAQ</p>
      <h2>Відповідаємо на часті питання</h2>
      <FaqBoy class="faq-boy" aria-hidden="true" />
      <FaqCup class="faq-cup" aria-hidden="true" />
      <div class="faq-list">
        {
          faqItems.map((item) => (
            <div class="faq-item-wrap">
              <DottedBorder/>
              <details class="faq-item">
                <summary>
                  {item.q}
                  <span class="faq-icon" />
                </summary>
                <div class="faq-content" set:html={item.a} />
              </details>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from "gsap";

  const reducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;
  const loops = new Map<Element, gsap.core.Timeline>();
  const scaleBlock = document.querySelector(".reason-wrapper");
  const queueItems = [...document.querySelectorAll(".reason-offline-list li")];

  if (scaleBlock && queueItems.length) {
    const setQueueState = (li: Element, state: string, badgeText: string) => {
      li.classList.remove("is-syncing", "is-done");
      if (state) li.classList.add(state);
      li.querySelector(".reasons-badge")!.textContent = badgeText;
    };

    const resetQueue = () => {
      setQueueState(queueItems[0], "is-done", "Відправлено");
      setQueueState(queueItems[1], "is-syncing", "Синхронізація");
      queueItems.slice(2).forEach((li) => setQueueState(li, "", "У черзі"));
    };

    if (reducedMotion) {
      // No looping animation: show both mocks in their final state
      gsap.set(".reason-scale-slot .reason-scale", { scale: 1 });
      queueItems.forEach((li) => setQueueState(li, "is-done", "Відправлено"));
    } else {
      const tl = gsap.timeline({ repeat: -1, repeatDelay: 2, paused: true });

      tl.call(resetQueue)
        // 1. terminals pop into the slots one by one
        .fromTo(
          ".reason-scale-slot .reason-scale",
          { scale: 0 },
          { scale: 1, duration: 0.5, ease: "back.out(1.2)", stagger: 0.5 }
        );

      // 2. then the queue advances one row every 0.9s
      queueItems.slice(1).forEach((li, idx) => {
        tl.call(
          () => {
            setQueueState(li, "is-done", "Відправлено");
            const next = queueItems[idx + 2];
            if (next) setQueueState(next, "is-syncing", "Синхронізація");
          },
          [],
          idx === 0 ? "+=0.6" : "+=0.9"
        );
      });

      loops.set(scaleBlock, tl);
    }
  }

  // Integrations sweep + courier route: ONE shared timeline (like the
  // terminals + offline queue pair), so the logo wave runs first, then the
  // courier walks the route, and both restart together on every repeat.
  const companiesGrid = document.querySelector(".reason-companies");
  const routeList = document.querySelector(".reason-timeline");

  if (companiesGrid && routeList) {
    const items = [...companiesGrid.querySelectorAll("li")];
    const stops = [...routeList.querySelectorAll("li")];

    const clearAll = () =>
      items.forEach((li) => li.classList.remove("is-active"));

    const setStep = (c: number) => {
      stops.forEach((li, k) => {
        li.classList.remove("is-current", "is-active", "is-done");
        if (k === c) li.classList.add("is-current");
        else if (k === c - 1) li.classList.add("is-active");
        else if (k < c - 1) li.classList.add("is-done");
      });
    };

    if (reducedMotion) {
      stops.forEach((li) => li.classList.add("is-done"));
    } else {
      let comboTl: gsap.core.Timeline;

      // (Re)build from the current layout — the logo columns depend on the
      // rendered grid (9 on desktop / 3 on mobile), so resize rebuilds it.
      const build = () => {
        if (comboTl) comboTl.kill();
        clearAll();

        const byLeft = new Map<number, Element[]>();
        items.forEach((li) => {
          const left = Math.round(li.getBoundingClientRect().left);
          if (!byLeft.has(left)) byLeft.set(left, []);
          byLeft.get(left)!.push(li);
        });
        const columns = [...byLeft.entries()]
          .sort((a, b) => a[0] - b[0])
          .map(([, cols]) => cols);

        const STEP = 1.4;
        const HOLD = STEP + 0.25;
        comboTl = gsap.timeline({ repeat: -1, repeatDelay: 1.6, paused: true });

        // route idles (all dashed) while the logo sweep is running
        comboTl.call(() => setStep(-1), [], 0);

        // 1. crossfade wave across the logo columns
        columns.forEach((col, i) => {
          comboTl.call(
            () => col.forEach((li) => li.classList.add("is-active")),
            [],
            i * STEP
          );
          comboTl.call(
            () => col.forEach((li) => li.classList.remove("is-active")),
            [],
            i * STEP + HOLD
          );
        });

        // 2. then the courier walks the route, one stop every 0.9s
        // ("+=" appends after the sweep's last call — same trick as the queue)
        for (let c = 0; c <= stops.length + 1; c++) {
          comboTl.call(() => setStep(c), [], c === 0 ? "+=0.6" : "+=0.9");
        }

        // refresh the registry — the shared observer reads the Map on every
        // event, so it picks up the rebuilt timeline automatically
        loops.set(companiesGrid, comboTl);
      };

      build();

      // Layout (and therefore columns) changes across breakpoints — rebuild
      let resizeTimer: number;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          build();
          comboTl.play();
        }, 200);
      });
    }
  }

  const postList = document.querySelector(".reason-post-list");
  if (postList) {
    const rows = [...postList.querySelectorAll("li")];

    const setPostState = (li: Element, done: boolean) => {
      li.classList.toggle("is-done", done);
      const status = li.querySelector(".reason-post-status")!;
      status.textContent = done
        ? "Доставлено"
        : (status.getAttribute("data-status") ?? "");
    };

    // Frame 1 of the mock: only the already-delivered first row is done
    const resetPost = () => rows.forEach((li, i) => setPostState(li, i === 0));

    if (reducedMotion) {
      rows.forEach((li) => setPostState(li, true));
    } else {
      const postTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 2,
        paused: true,
      });
      postTl.call(resetPost);
      rows.slice(1).forEach((li) => {
        postTl.call(() => setPostState(li, true), [], "+=1.2");
      });

      loops.set(postList, postTl);
    }
  }

  const stepsGrid = document.querySelector(".steps-grid");
  if (stepsGrid) {
    const cards = [...stepsGrid.querySelectorAll<HTMLElement>(".step-card")];
    const fillsOf = (card: HTMLElement) => [
      ...card.querySelectorAll<HTMLElement>("[data-fill], [data-activate]"),
    ];

    const fillClass = (el: HTMLElement) =>
      el.hasAttribute("data-activate") ? "is-active" : "is-filled";

    const reset = () => {
      cards.forEach((card) => {
        card.classList.remove("is-active", "is-done", "is-filled-done");
        fillsOf(card).forEach((el) =>
          el.classList.remove("is-filled", "is-active")
        );
      });
    };

    if (reducedMotion) {
      cards.forEach((card) => {
        card.classList.add("is-done", "is-filled-done");
        fillsOf(card).forEach((el) => el.classList.add(fillClass(el)));
      });
    } else {
      const stepsTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 2.5,
        paused: true,
      });
      stepsTl.call(reset);

      cards.forEach((card, i) => {
        // this card becomes the active (solid-framed) one; every card
        // before it has finished its animation and settles into is-done
        stepsTl.call(
          () =>
            cards.forEach((c, k) => {
              c.classList.toggle("is-active", c === card);
              c.classList.toggle("is-done", k < i);
            }),
          [],
          "+=0.6"
        );
        // then its fields / items fill one by one
        fillsOf(card).forEach((el) => {
          stepsTl.call(() => el.classList.add(fillClass(el)), [], "+=0.7");
        });
        // card 4's receipt frame lights up once its rows are in
        if (card.dataset.card === "4") {
          stepsTl.call(() => card.classList.add("is-filled-done"), [], "+=0.2");
        }
      });

      // the last card has finished too — mark it done for the final hold
      stepsTl.call(
        () => cards[cards.length - 1].classList.add("is-done"),
        [],
        "+=0.4"
      );

      loops.set(stepsGrid, stepsTl);
    }
  }

  // Slider testimonials

  const testimonialsSection =
    document.querySelector<HTMLElement>(".testimonials");
  if (testimonialsSection) {
    const track = testimonialsSection.querySelector<HTMLElement>(
      ".testimonials-track"
    )!;
    const cards = [
      ...track.querySelectorAll<HTMLElement>(".testimonials-card"),
    ];
    const bodies = cards.map(
      (card) => card.querySelector<HTMLElement>(".testimonials-body")!
    );
    const prevBtn = testimonialsSection.querySelector<HTMLButtonElement>(
      ".slider-btn--prev"
    )!;
    const nextBtn = testimonialsSection.querySelector<HTMLButtonElement>(
      ".slider-btn--next"
    )!;

    const desktop = window.matchMedia("(min-width: 1024px)");
    const PAD_ACTIVE = 16;
    const BODY_MARGIN = { top: 24, right: 40, bottom: 24, left: 24 };
    const ACTIVE_SHARE = 0.65;
    let index = 0;
    let bodyW = 0;
    let step = 0;
    const cardProps = (active: boolean) => ({
      padding: active ? PAD_ACTIVE : 16,
      backgroundColor: active ? "#ffffff" : "rgba(255,255,255,0)",
      borderColor: active ? "rgba(255,255,255,0)" : "rgba(255,255,255,0.35)",
    });
    const bodyProps = (active: boolean) => ({
      width: active ? bodyW : 0,
      marginTop: active ? BODY_MARGIN.top : 0,
      marginRight: active ? BODY_MARGIN.right : 0,
      marginBottom: active ? BODY_MARGIN.bottom : 0,
      marginLeft: active ? BODY_MARGIN.left : 0,
      autoAlpha: active ? 1 : 0,
    });

    const measure = () => {
      if (!desktop.matches) return;
      const mediaW = cards[0].querySelector<HTMLElement>(
        ".testimonials-media"
      )!.offsetWidth;
      // size against the .container, not the track: the track is as wide
      // as all its cards together, the container is the visible column
      const containerW = track.parentElement!.clientWidth;
      bodyW = Math.max(
        240,
        Math.round(containerW * ACTIVE_SHARE) -
          (PAD_ACTIVE * 2 + BODY_MARGIN.left + BODY_MARGIN.right + mediaW)
      );
      testimonialsSection.style.setProperty("--body-w", `${bodyW}px`);
      for (let k = 0; k < cards.length - 1; k++) {
        if (k !== index && k + 1 !== index) {
          step = cards[k + 1].offsetLeft - cards[k].offsetLeft;
          break;
        }
      }
    };

    const apply = (animate: boolean) => {
      const instant = reducedMotion || !animate;
      const tween: gsap.TweenVars = {
        duration: 1,
        ease: "expo.inOut",
        overwrite: "auto",
      };

      if (desktop.matches) {
        cards.forEach((card, k) => {
          const active = k === index;
          if (instant) {
            gsap.set(card, cardProps(active));
            gsap.set(bodies[k], bodyProps(active));
          } else {
            gsap.to(card, { ...cardProps(active), ...tween });
            gsap.to(bodies[k], { ...bodyProps(active), ...tween });
          }
        });
        const x = -index * step;
        instant ? gsap.set(track, { x }) : gsap.to(track, { x, ...tween });
      } else {
        const x = -(cards[index].offsetLeft - cards[0].offsetLeft);
        instant ? gsap.set(track, { x }) : gsap.to(track, { x, ...tween });
      }

      prevBtn.disabled = index === 0;
      nextBtn.disabled = index === cards.length - 1;
      cards.forEach((card, k) =>
        card.classList.toggle("is-current", k === index)
      );
    };

    const goTo = (i: number, animate = true) => {
      index = Math.max(0, Math.min(cards.length - 1, i));
      apply(animate);
    };

    const init = () => {
      apply(false);
      measure();
      apply(false);
    };

    prevBtn.addEventListener("click", () => goTo(index - 1));
    nextBtn.addEventListener("click", () => goTo(index + 1));

    cards.forEach((card, k) =>
      card.addEventListener("click", () => {
        if (desktop.matches && k !== index) goTo(k);
      })
    );

    let touchX = 0;
    track.addEventListener(
      "touchstart",
      (e) => (touchX = e.touches[0].clientX),
      { passive: true }
    );
    track.addEventListener(
      "touchend",
      (e) => {
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 40) goTo(index + (dx < 0 ? 1 : -1));
      },
      { passive: true }
    );

    let testimonialsResizeTimer: number;
    window.addEventListener("resize", () => {
      clearTimeout(testimonialsResizeTimer);
      testimonialsResizeTimer = window.setTimeout(() => {
        gsap.set([track, ...cards, ...bodies], { clearProps: "all" });
        init();
      }, 200);
    });

    init();

    if (!reducedMotion) {
      gsap.set(cards, { y: 48, autoAlpha: 0 });
      const introObserver = new IntersectionObserver(
        (entries) => {
          if (!entries[0].isIntersecting) return;
          introObserver.disconnect();
          gsap.to(cards, {
            y: 0,
            autoAlpha: 1,
            duration: 0.9,
            ease: "power3.out",
            stagger: 0.12,
          });
        },
        { threshold: 0.2 }
      );
      introObserver.observe(track);
    }
  }

  // API //
  const apiFlow = document.querySelector(".api-flow");
  if (apiFlow) {
    const apiNodes = [
      ...apiFlow.querySelectorAll(".api-node, .api-card, .api-row, .api-logo"),
    ];
    const clearApi = () =>
      apiNodes.forEach((n) => n.classList.remove("is-active"));

    if (reducedMotion) {
      apiNodes.forEach((n) => n.classList.add("is-active"));
    } else {
      const apiTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 1.8,
        paused: true,
      });
      apiTl.call(clearApi);
      apiNodes.forEach((n) => {
        apiTl.call(() => n.classList.add("is-active"), [], "+=1.0");
      });

      loops.set(apiFlow, apiTl);
    }
  }

  // Category slider: tabs auto-advance one by one (paused via loops/
  // loopObserver below, same as the API flow); any manual click on a tab or
  // arrow jumps straight to that slide and stops the autoplay for good.
  const categorySection = document.querySelector<HTMLElement>(".category");
  if (categorySection) {
    const tabs = [
      ...categorySection.querySelectorAll<HTMLButtonElement>(".category-tab"),
    ];
    const panelMedia = categorySection.querySelector<HTMLElement>(
      ".category-panel-media"
    )!;
    const panelImage = categorySection.querySelector<HTMLImageElement>(
      ".category-panel-image"
    )!;
    const panelText = categorySection.querySelector<HTMLElement>(
      ".category-panel-text"
    )!;
    const panelAuthorName = categorySection.querySelector<HTMLElement>(
      ".category-panel-author-name"
    )!;
    const panelRole = categorySection.querySelector<HTMLElement>(
      ".category-panel-role"
    )!;
    const panelLogos = categorySection.querySelector<HTMLElement>(
      ".category-panel-logos"
    )!;
    const prevBtn = categorySection.querySelector<HTMLButtonElement>(
      ".slider-btn--prev"
    )!;
    const nextBtn = categorySection.querySelector<HTMLButtonElement>(
      ".slider-btn--next"
    )!;

    let index = Math.max(
      0,
      tabs.findIndex((tab) => tab.classList.contains("is-active"))
    );
    let categoryTl: gsap.core.Timeline | undefined;

    const render = () => {
      const tab = tabs[index];
      const { image, imageW, imageH, quote, author, role, logos } = tab.dataset;
      panelImage.src = image!;
      panelImage.width = Number(imageW);
      panelImage.height = Number(imageH);
      panelText.textContent = quote!;
      panelAuthorName.textContent = author!;
      panelRole.textContent = role!;
      panelLogos.innerHTML = "";
      logos!.split("|").forEach((label) => {
        const li = document.createElement("li");
        li.textContent = label;
        panelLogos.append(li);
      });
    };

    const activate = (next: number, userTriggered = false) => {
      index = (next + tabs.length) % tabs.length;
      tabs.forEach((tab, k) => {
        const active = k === index;
        tab.classList.toggle("is-active", active);
        tab.setAttribute("aria-selected", String(active));
      });
      tabs[index].scrollIntoView({
        behavior: reducedMotion ? "auto" : "smooth",
        inline: "center",
        block: "nearest",
      });

      if (reducedMotion) {
        render();
      } else {
        gsap.to(panelMedia, {
          autoAlpha: 0,
          duration: 0.25,
          ease: "power1.in",
          overwrite: "auto",
          onComplete: () => {
            render();
            gsap.to(panelMedia, {
              autoAlpha: 1,
              duration: 0.35,
              ease: "power1.out",
              overwrite: "auto",
            });
          },
        });
      }

      if (userTriggered) {
        categoryTl?.pause();
        loops.delete(categorySection);
      }
    };

    tabs.forEach((tab, i) =>
      tab.addEventListener("click", () => activate(i, true))
    );
    prevBtn.addEventListener("click", () => activate(index - 1, true));
    nextBtn.addEventListener("click", () => activate(index + 1, true));

    if (!reducedMotion) {
      categoryTl = gsap.timeline({ repeat: -1, paused: true });
      categoryTl.call(() => activate(index + 1), [], 4);
      loops.set(categorySection, categoryTl);
    }
  }

  if (loops.size) {
    const loopObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const timeline = loops.get(entry.target);
          if (!timeline) return;
          entry.isIntersecting ? timeline.play() : timeline.pause();
        });
      },
      { threshold: 0.3 }
    );
    loops.forEach((_, el) => loopObserver.observe(el));
  }

  // FAQ: <details> can't animate natively, so the summary click is
  // intercepted and the answer is tweened by GSAP (it can animate height to
  // "auto"); [open] is only removed after the collapse finishes
  document
    .querySelectorAll<HTMLDetailsElement>(".faq-item")
    .forEach((details) => {
      const summary = details.querySelector("summary")!;
      const content = details.querySelector<HTMLElement>(".faq-content")!;
      const wrap = details.closest(".faq-item-wrap");

      summary.addEventListener("click", (e) => {
        e.preventDefault();
        // is-open (not details.open) drives the toggle: [open] stays set
        // until the collapse tween finishes, so a click mid-collapse should
        // reopen, tweening from the current height
        const isOpen = details.classList.contains("is-open");

        if (!isOpen) {
          wrap?.classList.add("is-open");
          details.classList.add("is-open");
          if (!details.open) {
            details.open = true;
            gsap.set(content, {
              height: 0,
              opacity: 0,
              marginTop: 0,
              overflow: "hidden",
            });
          }
          gsap.to(content, {
            height: "auto",
            opacity: 1,
            marginTop: 16,
            duration: 0.2,
            ease: "power1.out",
            overwrite: true,
            clearProps: "all",
          });
        } else {
          wrap?.classList.remove("is-open");
          details.classList.remove("is-open");
          gsap.to(content, {
            height: 0,
            opacity: 0,
            marginTop: 0,
            overflow: "hidden",
            duration: 0.2,
            ease: "power1.in",
            overwrite: true,
            onComplete: () => {
              details.open = false;
              gsap.set(content, { clearProps: "all" });
            },
          });
        }
      });
    });
</script>
