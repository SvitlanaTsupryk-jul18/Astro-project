  </section>

  <section class="support">
    <div class="container">
      <p class="subtitle">Підтримка</p>
      <h2>Наша служба турботи<br />завжди допоможе</h2>
      <div class="support-card">
        <DottedBorder radius={16}/>
        <div class="support-info">
          <a class="support-phone" href="tel:0800330676">0 800 330 676</a>
          <div class="support-actions">
            <a
              class="support-btn"
              href="https://t.me/checkbox_help"
              target="_blank"
              rel="noopener"
            >
              <IconTelegram />
              Зверніться у Telegram
            </a>
            <a
              class="support-btn"
              href="viber://pa?chatURI=checkbox"
              target="_blank"
              rel="noopener"
            >
              <IconViber />
              Зверніться у Viber
            </a>
