  const receiptCounter = document.querySelector("[data-receipt-counter]");
if (receiptCounter) {
  const base = Number(receiptCounter.textContent!.replace(/\D/g, "")); // 2582509485, value as of 00:00 today
  const perSecond = 33;

  const now = new Date();
  const midnight = new Date(2026, 6, 20, 0, 0, 0, 0).getTime();

  const update = () => {
    const elapsedSeconds = Math.floor((Date.now() - midnight) / 1000);
    const receipts = base + elapsedSeconds * perSecond;
    receiptCounter.textContent = String(receipts).replace(
      /\B(?=(\d{3})+(?!\d))/g,
      " "
    );
  };

  update(); // show the correct number immediately, don't wait 1s for the first tick
  setInterval(update, 1000);
}

  const loops = new Map<Element, gsap.core.Timeline>();

