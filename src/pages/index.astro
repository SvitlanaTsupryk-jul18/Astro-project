  <section class="blog">
    <div class="container">
      <p class="subtitle">Корисне з цікавим</p>
      <h2>Корисні статті в блозі</h2>
      <ul class="blog-list">
        {
          blogPosts.map((post) => (
            <li>
              <a class="blog-card" href="/blog/">
                <Image
                  class="blog-image"
                  src={post.image}
                  alt={post.title}
                  loading="lazy"
                />
                <span class="blog-tag">{post.category}</span>
                <h3 class="blog-card-title">{post.title}</h3>
                <p class="blog-author">{post.author}</p>
                <p class="blog-meta">
                  {post.date}
                  <span class="blog-read">{post.readTime}</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
