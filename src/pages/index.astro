<script>
  import { gsap } from "gsap";

  const reducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  // Every looping mock registers its timeline here (element → timeline);
  // one shared IntersectionObserver at the bottom plays/pauses them, so a
  // loop never runs while its block is off screen.
  const loops = new Map<Element, gsap.core.Timeline>();

  // Reasons mocks: one infinite GSAP timeline — the terminals pop into the
  // slots, then the offline queue syncs row by row, hold, repeat.
  const scaleBlock = document.querySelector(".reason-wrapper");
  const queueItems = [...document.querySelectorAll(".reason-offline-list li")];

  if (scaleBlock && queueItems.length) {
    const setQueueState = (li: Element, state: string, badgeText: string) => {
      li.classList.remove("is-syncing", "is-done");
      if (state) li.classList.add(state);
      li.querySelector(".reasons-badge")!.textContent = badgeText;
    };

    // Frame 1 of the mock: first row already sent, second one syncing
    const resetQueue = () => {
      setQueueState(queueItems[0], "is-done", "Відправлено");
      setQueueState(queueItems[1], "is-syncing", "Синхронізація");
      queueItems.slice(2).forEach((li) => setQueueState(li, "", "У черзі"));
    };

    if (reducedMotion) {
      // No looping animation: show both mocks in their final state
      gsap.set(".reason-scale-slot .reason-scale", { scale: 1 });
      queueItems.forEach((li) => setQueueState(li, "is-done", "Відправлено"));
    } else {
      const tl = gsap.timeline({ repeat: -1, repeatDelay: 2, paused: true });

      tl.call(resetQueue)
        // 1. terminals pop into the slots one by one
        .fromTo(
          ".reason-scale-slot .reason-scale",
          { scale: 0 },
          { scale: 1, duration: 0.5, ease: "back.out(1.2)", stagger: 0.5 }
        );

      // 2. then the queue advances one row every 0.9s
      queueItems.slice(1).forEach((li, idx) => {
        tl.call(
          () => {
            setQueueState(li, "is-done", "Відправлено");
            const next = queueItems[idx + 2];
            if (next) setQueueState(next, "is-syncing", "Синхронізація");
          },
          [],
          idx === 0 ? "+=0.6" : "+=0.9"
        );
      });

      loops.set(scaleBlock, tl);
    }
  }

  // Integrations sweep + courier route: ONE shared timeline (like the
  // terminals + offline queue pair), so the logo wave runs first, then the
  // courier walks the route, and both restart together on every repeat.
  const companiesGrid = document.querySelector(".reason-companies");
  const routeList = document.querySelector(".reason-timeline");

  if (companiesGrid && routeList) {
    const items = [...companiesGrid.querySelectorAll("li")];
    const stops = [...routeList.querySelectorAll("li")];

    const clearAll = () =>
      items.forEach((li) => li.classList.remove("is-active"));

    const setStep = (c: number) => {
      stops.forEach((li, k) => {
        li.classList.remove("is-current", "is-active", "is-done");
        if (k === c) li.classList.add("is-current");
        else if (k === c - 1) li.classList.add("is-active");
        else if (k < c - 1) li.classList.add("is-done");
      });
    };

    if (reducedMotion) {
      stops.forEach((li) => li.classList.add("is-done"));
    } else {
      let comboTl: gsap.core.Timeline;

      // (Re)build from the current layout — the logo columns depend on the
      // rendered grid (9 on desktop / 3 on mobile), so resize rebuilds it.
      const build = () => {
        if (comboTl) comboTl.kill();
        clearAll();

        const byLeft = new Map<number, Element[]>();
        items.forEach((li) => {
          const left = Math.round(li.getBoundingClientRect().left);
          if (!byLeft.has(left)) byLeft.set(left, []);
          byLeft.get(left)!.push(li);
        });
        const columns = [...byLeft.entries()]
          .sort((a, b) => a[0] - b[0])
          .map(([, cols]) => cols);

        const STEP = 1.4;
        const HOLD = STEP + 0.25;
        comboTl = gsap.timeline({ repeat: -1, repeatDelay: 1.6, paused: true });

        // route idles (all dashed) while the logo sweep is running
        comboTl.call(() => setStep(-1), [], 0);

        // 1. crossfade wave across the logo columns
        columns.forEach((col, i) => {
          comboTl.call(
            () => col.forEach((li) => li.classList.add("is-active")),
            [],
            i * STEP
          );
          comboTl.call(
            () => col.forEach((li) => li.classList.remove("is-active")),
            [],
            i * STEP + HOLD
          );
        });

        // 2. then the courier walks the route, one stop every 0.9s
        // ("+=" appends after the sweep's last call — same trick as the queue)
        for (let c = 0; c <= stops.length + 1; c++) {
          comboTl.call(() => setStep(c), [], c === 0 ? "+=0.6" : "+=0.9");
        }

        // refresh the registry — the shared observer reads the Map on every
        // event, so it picks up the rebuilt timeline automatically
        loops.set(companiesGrid, comboTl);
      };

      build();

      // Layout (and therefore columns) changes across breakpoints — rebuild
      let resizeTimer: number;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          build();
          comboTl.play();
        }, 200);
      });
    }
  }

  // Post shipments mock: rows flip to "Доставлено" one by one, hold, then
  // reset to the original statuses (kept in data-status) and repeat.
  const postList = document.querySelector(".reason-post-list");
  if (postList) {
    const rows = [...postList.querySelectorAll("li")];

    const setPostState = (li: Element, done: boolean) => {
      li.classList.toggle("is-done", done);
      const status = li.querySelector(".reason-post-status")!;
      status.textContent = done
        ? "Доставлено"
        : (status.getAttribute("data-status") ?? "");
    };

    // Frame 1 of the mock: only the already-delivered first row is done
    const resetPost = () => rows.forEach((li, i) => setPostState(li, i === 0));

    if (reducedMotion) {
      rows.forEach((li) => setPostState(li, true));
    } else {
      const postTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 2,
        paused: true,
      });
      postTl.call(resetPost);
      rows.slice(1).forEach((li) => {
        postTl.call(() => setPostState(li, true), [], "+=1.2");
      });

      loops.set(postList, postTl);
    }
  }

  // Onboarding steps: ONE master timeline. Each card fills its own mini-UI in
  // turn, and — because everything sits on a single sequential timeline — a
  // card only starts once the previous card has finished.
  const stepsGrid = document.querySelector(".steps-grid");
  if (stepsGrid) {
    const cards = [...stepsGrid.querySelectorAll<HTMLElement>(".step-card")];
    // per card: the elements it fills, in order
    const fillsOf = (card: HTMLElement) => [
      ...card.querySelectorAll<HTMLElement>("[data-fill], [data-activate]"),
    ];

    const fillClass = (el: HTMLElement) =>
      el.hasAttribute("data-activate") ? "is-active" : "is-filled";

    const reset = () => {
      cards.forEach((card) => {
        card.classList.remove("is-active", "is-done", "is-filled-done");
        fillsOf(card).forEach((el) =>
          el.classList.remove("is-filled", "is-active")
        );
      });
    };

    if (reducedMotion) {
      cards.forEach((card) => {
        card.classList.add("is-done", "is-filled-done");
        fillsOf(card).forEach((el) => el.classList.add(fillClass(el)));
      });
    } else {
      const stepsTl = gsap.timeline({
        repeat: -1,
        repeatDelay: 2.5,
        paused: true,
      });
      stepsTl.call(reset);

      cards.forEach((card, i) => {
        // this card becomes the active (solid-framed) one; every card
        // before it has finished its animation and settles into is-done
        stepsTl.call(
          () =>
            cards.forEach((c, k) => {
              c.classList.toggle("is-active", c === card);
              c.classList.toggle("is-done", k < i);
            }),
          [],
          "+=0.6"
        );
        // then its fields / items fill one by one
        fillsOf(card).forEach((el) => {
          stepsTl.call(() => el.classList.add(fillClass(el)), [], "+=0.7");
        });
        // card 4's receipt frame lights up once its rows are in
        if (card.dataset.card === "4") {
          stepsTl.call(() => card.classList.add("is-filled-done"), [], "+=0.2");
        }
      });

      // the last card has finished too — mark it done for the final hold
      stepsTl.call(
        () => cards[cards.length - 1].classList.add("is-done"),
        [],
        "+=0.4"
      );

      loops.set(stepsGrid, stepsTl);
    }
  }

  // Cases slider: arrows (and swipe) tween the track between card positions.
  const sliderSection = document.querySelector<HTMLElement>(".slider");
  if (sliderSection) {
    const track = sliderSection.querySelector<HTMLElement>(".slider-track")!;
    const cards = [...track.querySelectorAll<HTMLElement>(".slider-card")];
    const prevBtn = sliderSection.querySelector<HTMLButtonElement>(
      ".slider-arrow--prev"
    )!;
    const nextBtn = sliderSection.querySelector<HTMLButtonElement>(
      ".slider-arrow--next"
    )!;

    let index = 0;

    const goTo = (i: number, animate = true) => {
      index = Math.max(0, Math.min(cards.length - 1, i));
      // offsetLeft is measured against the same parent for every card, so
      // the delta to the first card is the track shift — gap included
      const x = -(cards[index].offsetLeft - cards[0].offsetLeft);

      if (reducedMotion || !animate) {
        gsap.set(track, { x });
      } else {
        gsap.to(track, { x, duration: 1, ease: "expo.inOut", overwrite: true });
      }

      prevBtn.disabled = index === 0;
      nextBtn.disabled = index === cards.length - 1;
      cards.forEach((card, k) =>
        card.classList.toggle("is-current", k === index)
      );
    };

    prevBtn.addEventListener("click", () => goTo(index - 1));
    nextBtn.addEventListener("click", () => goTo(index + 1));

    // swipe: a quick horizontal drag of 40px+ flips one card
    let touchX = 0;
    track.addEventListener(
      "touchstart",
      (e) => (touchX = e.touches[0].clientX),
      { passive: true }
    );
    track.addEventListener(
      "touchend",
      (e) => {
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 40) goTo(index + (dx < 0 ? 1 : -1));
      },
      { passive: true }
    );

    // card widths change across breakpoints — re-align without animating
    window.addEventListener("resize", () => goTo(index, false));

    goTo(0, false);

    // entrance: cards rise in one after another the first time they appear
    if (!reducedMotion) {
      gsap.set(cards, { y: 48, autoAlpha: 0 });
      const introObserver = new IntersectionObserver(
        (entries) => {
          if (!entries[0].isIntersecting) return;
          introObserver.disconnect();
          gsap.to(cards, {
            y: 0,
            autoAlpha: 1,
            duration: 0.9,
            ease: "power3.out",
            stagger: 0.12,
          });
        },
        { threshold: 0.2 }
      );
      introObserver.observe(track);
    }
  }

  // API flow: the glow sweeps down the chain node by node, holds, resets.
  const apiFlow = document.querySelector(".api-flow");
  if (apiFlow) {
    const apiNodes = [
      ...apiFlow.querySelectorAll(".api-node, .api-card, .api-logo"),
    ];
    const clearApi = () =>
      apiNodes.forEach((n) => n.classList.remove("is-active"));

    if (reducedMotion) {
      apiNodes.forEach((n) => n.classList.add("is-active"));
    } else {
      const apiTl = gsap.timeline({ repeat: -1, repeatDelay: 1.8, paused: true });
      apiTl.call(clearApi);
      apiNodes.forEach((n) => {
        apiTl.call(() => n.classList.add("is-active"), [], "+=0.45");
      });

      loops.set(apiFlow, apiTl);
    }
  }

  if (loops.size) {
    const loopObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const timeline = loops.get(entry.target);
          if (!timeline) return;
          entry.isIntersecting ? timeline.play() : timeline.pause();
        });
      },
      { threshold: 0.3 }
    );
    loops.forEach((_, el) => loopObserver.observe(el));
  }
</script>
