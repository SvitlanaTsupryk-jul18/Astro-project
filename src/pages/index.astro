    );
  });
  const scaleBlock = document.querySelector(".reason-wrapper");
  const queueItems = [...document.querySelectorAll(".reason-offline-list li")];

  if (scaleBlock && queueItems.length) {
    const setQueueState = (li: Element, state: string, badgeText: string) => {
      li.classList.remove("is-syncing", "is-done");
      if (state) li.classList.add(state);
      li.querySelector(".reasons-badge")!.textContent = badgeText;
    };

    const resetQueue = () => {
      setQueueState(queueItems[0], "is-done", "Відправлено");
      setQueueState(queueItems[1], "is-syncing", "Синхронізація");
      queueItems.slice(2).forEach((li) => setQueueState(li, "", "У черзі"));
    };

    if (reducedMotion) {
      // No looping animation: show both mocks in their final state
      gsap.set(".reason-scale-slot .reason-scale", { scale: 1 });
      queueItems.forEach((li) => setQueueState(li, "is-done", "Відправлено"));
    } else {
      const tl = gsap.timeline({ repeat: -1, repeatDelay: 2, paused: true });

      tl.call(resetQueue)
        // 1. terminals pop into the slots one by one
        .fromTo(
          ".reason-scale-slot .reason-scale",
          { scale: 0 },
          { scale: 1, duration: 0.5, ease: "back.out(1.2)", stagger: 0.5 }
        );

      // 2. then the queue advances one row every 0.9s
      queueItems.slice(1).forEach((li, idx) => {
        tl.call(
          () => {
            setQueueState(li, "is-done", "Відправлено");
            const next = queueItems[idx + 2];
            if (next) setQueueState(next, "is-syncing", "Синхронізація");
          },
          [],
          "+=0.5"
        );
      });

      loops.set(scaleBlock, tl);
    }
  }

  // Integrations sweep + courier route: ONE shared timeline (like the
  // terminals + offline queue pair), so the logo wave runs first, then the
  // courier walks the route, and both restart together on every repeat.
  const companiesGrid = document.querySelector(".reason-companies");
  const routeList = document.querySelector(".reason-timeline");

  if (companiesGrid && routeList) {
    const items = [...companiesGrid.querySelectorAll("li")];
    const stops = [...routeList.querySelectorAll("li")];

    const clearAll = () =>
      items.forEach((li) => li.classList.remove("is-active"));

    const setStep = (c: number) => {
      stops.forEach((li, k) => {
        li.classList.remove("is-current", "is-active", "is-done");
        if (k === c) li.classList.add("is-current");
        else if (k === c - 1) li.classList.add("is-active");
        else if (k < c - 1) li.classList.add("is-done");
      });
    };

    if (reducedMotion) {
      stops.forEach((li) => li.classList.add("is-done"));
    } else {
      let comboTl: gsap.core.Timeline;

      // (Re)build from the current layout — the logo columns depend on the
      // rendered grid (9 on desktop / 3 on mobile), so resize rebuilds it.
      const build = () => {
        if (comboTl) comboTl.kill();
        clearAll();

        const byLeft = new Map<number, Element[]>();
        items.forEach((li) => {
          const left = Math.round(li.getBoundingClientRect().left);
          if (!byLeft.has(left)) byLeft.set(left, []);
          byLeft.get(left)!.push(li);
        });
        const columns = [...byLeft.entries()]
          .sort((a, b) => a[0] - b[0])
          .map(([, cols]) => cols);

        const STEP = .35;
        const HOLD = STEP + 0.2;
        comboTl = gsap.timeline({ repeat: -1, repeatDelay: 1.6, paused: true });

        // route idles (all dashed) while the logo sweep is running
        comboTl.call(() => setStep(-1), [], 0);

        // 1. crossfade wave across the logo columns
        columns.forEach((col, i) => {
          comboTl.call(
            () => col.forEach((li) => li.classList.add("is-active")),
            [],
            i * STEP
          );
          comboTl.call(
            () => col.forEach((li) => li.classList.remove("is-active")),
            [],
            i * STEP + HOLD
          );
        });

        // 2. then the courier walks the route, one stop every 0.9s
        // ("+=" appends after the sweep's last call — same trick as the queue)
        for (let c = 0; c <= stops.length + 1; c++) {
          comboTl.call(() => setStep(c), [], c === 0 ? "+=0.45" : "+=0.6");
        }

        // refresh the registry — the shared observer reads the Map on every
        // event, so it picks up the rebuilt timeline automatically
        loops.set(companiesGrid, comboTl);
      };

      build();

      // Layout (and therefore columns) changes across breakpoints — rebuild
      resizeHandlers.push(() => {
        build();
        comboTl.play();
      });
    }
  }

