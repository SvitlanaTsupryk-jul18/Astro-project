---
import '../styles/general.css';
import { Font } from 'astro:assets';

const { title, description, ogImage, ogType = 'product', noindex = false } = Astro.props;
const isNoindex = noindex || import.meta.env.DEV || import.meta.env.NOINDEX === 'true';

const canonicalURL = Astro.site
    ? new URL(Astro.url.pathname, Astro.site)
    : null;

const defaultOgImage = '/static/images/mainPage/og.png';

// Organization markup belongs on the homepage only (SEO spec)
const basePath = import.meta.env.BASE_URL.replace(/\/+$/, '');
const isHome = Astro.url.pathname.replace(/\/+$/, '') === basePath;

const logoURL = Astro.site
    ? new URL(`${basePath}/static/images/logo.svg`, Astro.site)
    : null;

const organizationLd = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Чекбокс",
    "url": "https://checkbox.ua/",
    "logo": logoURL ? String(logoURL) : undefined,
    "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "0800 330 676",
        "contactType": "customer service",
        "areaServed": "UA"
    },
    "sameAs": [
        "https://www.facebook.com/CheckboxUkraine",
        "https://www.instagram.com/checkbox.ua/",
        "https://www.youtube.com/channel/UCTEkKa-Z2DreSefLoMl97JA"
    ]
};
---

<meta charset="UTF-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
<Font cssVariable="--font-fixel-text" preload={[{ weight: '400' }]} />
<Font cssVariable="--font-jetbrains-mono" />
<title>{title}</title>
<meta name="description" content={description}>
<meta name="og:title" property="og:title" content={title}>
<meta name="og:type" property="og:type" content={ogType}>
<meta name="og:description" property="og:description" content={description}>
<meta name="og:image" property="og:image" content={ogImage || defaultOgImage}>
{canonicalURL && <meta name="og:url" property="og:url" content={String(canonicalURL)}>}
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="theme-color" content="#3f18a0">
<meta name="apple-mobile-web-app-status-bar-style" content="#3f18a0">
{isNoindex && <meta name="robots" content="noindex, nofollow">}
{isHome && <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationLd)} />}
<link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`.replace("//", "/")} type="image/x-icon"/>
<link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/apple-touch-icon.png`.replace("//", "/")}/>
{canonicalURL && <link rel="canonical" href={String(canonicalURL)}/>}