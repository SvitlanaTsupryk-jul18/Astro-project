  .footer-group {
    padding: 24px;
    align-self: start;
    position: relative;
  }

  .footer-group-title {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-white);
    padding-bottom: 8px;

    svg {
      margin-top: 6px;
    }
  }

  .footer-group-desc {
    color: var(--color-grey-light);
  }

  .footer-group-brands {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 24px;
    margin-top: 32px;

    a g {
      transition: all 0.3s;
    }

    a:hover g {
      opacity: 0.9;
    }
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    margin-top: 48px;
  }

  .footer-col {
    display: contents;
  }

  .footer-nav-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-bottom: 48px;
    background: none;
    border: none;
    color: var(--color-white);
    font-size: 20px;
    font-weight: 600;
    cursor: pointer;
  }

  .footer-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .footer-nav-group.is-open .footer-chevron {
    transform: rotate(180deg);
  }

  .footer-nav-content {
    display: none;
    padding-bottom: 18px;
  }

  .footer-nav-group.is-open .footer-nav-content {
    display: block;
  }

  .footer-nav-content ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-nav-content a {
    color: var(--color-grey-light);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-nav-content a:hover {
    color: var(--color-white);
  }

  .footer-phone-divider {
    width: 32px;
    height: 1px;
    background: var(--color-grey-light);
    margin: 16px 0;
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-grey-light);
    text-decoration: none;
    font-family: var(--font-mono);
    font-weight: 500;
    line-height: 18px;
    letter-spacing: -0.16px;
  }

  /* Bottom legal bar */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-top: 32px;
    background: repeating-linear-gradient(
      90deg,
      #ffffff7a 0,
      #ffffff7a 1px,
      transparent 1px,
      transparent 8px
    )
    0 0 / 8px 1px repeat-x;
    color: var(--color-grey-light);
  }

  .footer-legal-info,
  .footer-legal-links {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-grey-light);
    display: flex;
    flex-direction: column;
    gap: 32px;

    a {
      color: inherit;
      text-decoration: none;
    }
  }

  .footer-legal-links a:hover {
    color: var(--color-white);
  }

  @media (min-width: 1024px) {
    .footer {
      padding: 160px 0 32px;
    }

    .footer-top {
      grid-template-columns: 567px 1fr;
      gap: 64px;
      justify-content: space-between;
      padding-bottom: 0;
    }

    .footer-group {
      max-width: 610px;
      justify-self: end;
    }

    .footer-group-brands {
      flex-wrap: nowrap;
      justify-content: space-between;
    }

    .footer-group-title {
      display: flex;
      align-items: center;
      gap: 8px;

      svg {
        display: inline-block;
        margin: 0;
      }
    }

    .footer-group-desc {
      width: 434px;
    }

    .footer-payments {
      margin-bottom: 0;
    }

    .footer-nav {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      margin: 174px 0;
    }

    .footer-col {
      display: block;
    }

    .footer-nav-group {
      border-top: none;
    }

    .footer-nav-group + .footer-nav-group {
      margin-top: 64px;
    }

    .footer-nav-toggle {
      padding: 0;
      margin-bottom: 16px;
      pointer-events: none;
    }

    .footer-chevron {
      display: none;
    }

    .footer-nav-content {
      display: block;
      padding-bottom: 0;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    .footer-legal-info {
      flex-direction: row;
      gap: 24px;
    }

    .footer-legal-links {
      flex-direction: row;
      gap: 24px;
    }
