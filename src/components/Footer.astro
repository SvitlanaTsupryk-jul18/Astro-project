<script>
  document.querySelectorAll(".footer-nav-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.closest(".footer-nav-group");
      if (!group) return;
      const open = group.classList.toggle("is-open");
      btn.setAttribute("aria-expanded", String(open));
    });
  });
</script>

<style>
  .footer {
    background: var(--color-black);
    color: var(--color-white);
    padding-block: 120px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    /* gap: 48px; */
    padding-bottom: 24px;
  }

  .footer-text {
    color: var(--color-grey-light);
    padding: 32px 0;

    strong {
      font-weight: 500;
      color: var(--color-white);
    }
  }

  .footer-desc strong {
    color: #fff;
    font-weight: 600;
  }

  .footer-socials {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 8px;
    color: var(--color-white);
    position: relative;

    svg {
      transition: all 0.3s;
    }
  }

  .footer-social:hover svg {
    transform: scale(1.1);
  }

  .footer-payments {
    display: flex;
    gap: 10px;
    margin: 20px 0 64px;
  }

