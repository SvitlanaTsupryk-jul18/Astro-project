<script>
  const header = document.getElementById("header");
  const burger = document.getElementById("burger");

  burger?.addEventListener("click", () => {
    const open = header?.classList.toggle("active");
    burger.setAttribute("aria-expanded", String(Boolean(open)));
    document.body.style.overflow = open ? "hidden" : "";
  });

  // Mobile only: clicking a trigger toggles its parent accordion (.show);
  // on desktop the same dropdowns open on hover via CSS instead.
  function bindMobileAccordion(trigger: HTMLElement) {
    trigger.addEventListener("click", () => {
      if (window.innerWidth >= 1024) return;
      const shown = trigger.parentElement?.classList.toggle("show");
      trigger.setAttribute("aria-expanded", String(Boolean(shown)));
    });
  }

  document
    .querySelectorAll<HTMLElement>(
      ".header .list, .header .header-support-btn, .header button.innerList-label"
    )
    .forEach(bindMobileAccordion);
</script>

<style>
  /* ── Bar ──────────────────────────── ────────────────── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    background: var(--border-dotted-bottom);
    background-color: var(--color-bg);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo-icon {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(1);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .logo:hover .logo-icon {
    transform: scale(1.07);
  }

  .logo-word {
    display: none;
  }

  .burger {
    position: relative;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
  }

  .burger div {
    position: absolute;
    top: 50%;
    left: 3px;
    width: 22px;
    height: 3px;
    background: var(--color-black);
    transition: background 0.18s ease;
  }

  .burger div::before,
  .burger div::after {
    content: "";
    position: absolute;
    right: 0;
    width: 100%;
    height: 100%;
    background: var(--color-black);
    transition:
      transform 0.18s ease,
      top 0.18s ease,
      bottom 0.18s ease;
    transform-origin: center;
  }

  .burger div::before {
    top: -8px;
  }
  .burger div::after {
    bottom: -8px;
  }

  .header.active .burger div {
    background: transparent;
  }
  .header.active .burger div::before {
    top: 0;
    transform: rotate(45deg);
  }
  .header.active .burger div::after {
    bottom: 0;
    transform: rotate(-45deg);
  }

  .nav {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    padding: 84px 24px 40px;
    overflow-y: auto;
    transform: translateY(-100%);
    transition: transform 0.35s ease;
  }

  .nav::-webkit-scrollbar {
    width: 4px;
  }
  .nav::-webkit-scrollbar-thumb {
    background: rgb(0, 0, 0);
    /* border-radius: 2px; */
  }
  .nav::-webkit-scrollbar-track {
    background: transparent;
    margin: 16px 0px;
  }

  .header.active .nav {
    transform: none;
  }

  .header-nav {
    display: flex;
    flex-direction: column;
  }

  .header-nav > a,
  .list {
